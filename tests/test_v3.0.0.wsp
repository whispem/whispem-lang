# Whispem v3.0.0 — Full Test Suite
print "\n=== v3.0.0 Test Suite ==="

# ── Arithmetic ────────────────────────────────────────────────────────────────
print "\n=== Arithmetic ==="
print 2 + 3      # 5
print 10 - 4     # 6
print 6 * 7      # 42
print 20 / 4     # 5
print 10 % 3     # 1
print 15 % 5     # 0
print -5          # -5
print -(3 + 2)   # -5

# ── Variables ─────────────────────────────────────────────────────────────────
print "\n=== Variables ==="
let name = "Em"
let age = 26
print name        # Em
print age         # 26
let age = age + 1
print age         # 27

# ── Strings ───────────────────────────────────────────────────────────────────
print "\n=== Strings ==="
print "Hello, " + "world!"
print "Age: " + 26
print length("Whispem")   # 7
print char_at("abcde", 2) # c
print substr("Hello", 1, 3) # ell
print ord("A")             # 65
print num_to_str(42)       # 42
print str_to_num("3.14")  # 3.14

# String escapes
print "line1\nline2"
print "tab\there"
print "say \"hi\""

# ── Booleans & Truthiness ────────────────────────────────────────────────────
print "\n=== Booleans ==="
print true
print false
print not true     # false
print not false    # true

print "\n=== Truthiness ==="
if 0 { print "FAIL" } else { print "0 is falsy" }
if "" { print "FAIL" } else { print "empty string is falsy" }
if [] { print "FAIL" } else { print "empty array is falsy" }
if {} { print "FAIL" } else { print "empty dict is falsy" }
if 1 { print "1 is truthy" }
if "x" { print "non-empty string is truthy" }
if [1] { print "non-empty array is truthy" }
if {"a": 1} { print "non-empty dict is truthy" }

# ── Comparisons ───────────────────────────────────────────────────────────────
print "\n=== Comparisons ==="
print 5 == 5      # true
print 5 != 3      # true
print 3 < 5       # true
print 5 > 3       # true
print 3 <= 3      # true
print 5 >= 5      # true
print "apple" < "banana"  # true

# ── Logical operators ─────────────────────────────────────────────────────────
print "\n=== Logical ==="
print true and true    # true
print true and false   # false
print false or true    # true
print false or false   # false

# Short-circuit
fn side(label) {
    print "evaluated: " + label
    return true
}
if false and side("should not run") { print "FAIL" }
if true or side("should not run either") { print "short-circuit works" }

# ── Conditionals ──────────────────────────────────────────────────────────────
print "\n=== Conditionals ==="
let x = 10
if x > 5 {
    print "big"
} else {
    print "small"
}

if x == 1 {
    print "one"
} else {
    if x == 10 {
        print "ten"
    } else {
        print "other"
    }
}

# ── While loops ───────────────────────────────────────────────────────────────
print "\n=== While ==="
let i = 0
while i < 5 {
    print i
    let i = i + 1
}

# ── For loops ─────────────────────────────────────────────────────────────────
print "\n=== For ==="
let fruits = ["apple", "banana", "cherry"]
for fruit in fruits {
    print fruit
}

for n in range(1, 4) {
    print n
}

# ── Break / Continue ──────────────────────────────────────────────────────────
print "\n=== Break / Continue ==="
let i = 0
while i < 10 {
    let i = i + 1
    if i % 2 == 0 { continue }
    if i > 7 { break }
    print i
}
# Expected: 1 3 5 7

# ── Functions ─────────────────────────────────────────────────────────────────
print "\n=== Functions ==="

fn add(a, b) { return a + b }
print add(3, 4)   # 7

fn greet(name) { return "Hello, " + name + "!" }
print greet("Em") # Hello, Em!

# Forward call
print triple(5)   # 15
fn triple(n) { return n * 3 }

# No params
fn pi() { return 3.14159 }
print pi()

# Void function
fn say_hi() { print "hi!" }
say_hi()

# Recursion
fn factorial(n) {
    if n <= 1 { return 1 }
    return n * factorial(n - 1)
}
print factorial(10)   # 3628800

# Global variable access from function
let greeting = "Bonjour"
fn make_greeting(name) {
    return greeting + ", " + name
}
print make_greeting("Em")  # Bonjour, Em

# ── Arrays ────────────────────────────────────────────────────────────────────
print "\n=== Arrays ==="
let arr = [10, 20, 30, 40, 50]
print arr[0]          # 10
print arr[4]          # 50
print length(arr)     # 5

# Index assignment
arr[0] = 99
print arr[0]          # 99

# push / pop / reverse / slice
let arr2 = push(arr, 60)
print arr2
let popped = pop(arr2)
print popped
let rev = reverse([1, 2, 3])
print rev             # [3, 2, 1]
let sl = slice([10, 20, 30, 40, 50], 1, 4)
print sl              # [20, 30, 40]

# range
print range(0, 5)     # [0, 1, 2, 3, 4]

# ── Dictionaries ──────────────────────────────────────────────────────────────
print "\n=== Dictionaries ==="
let person = {"name": "Emilie", "age": 26, "city": "Marseille"}
print person["name"]  # Emilie
print person["age"]   # 26

# Index assignment
person["city"] = "Paris"
print person["city"]  # Paris

# New key
person["job"] = "dev"
print person["job"]   # dev

# has_key / keys / values / length
print has_key(person, "name")    # true
print has_key(person, "foo")     # false
print keys(person)
print values(person)
print length(person)             # 4

# Dict in function
fn describe(p) {
    return p["name"] + ", " + p["age"] + ", " + p["city"]
}
print describe(person)

# Nested dict
let config = {
    "server": {"host": "localhost", "port": 8080},
    "debug": true
}
print config["debug"]            # true
print config["server"]["host"]   # localhost

# ── FizzBuzz ──────────────────────────────────────────────────────────────────
print "\n=== FizzBuzz ==="
for n in range(1, 16) {
    if n % 15 == 0 {
        print "FizzBuzz"
    } else {
        if n % 3 == 0 {
            print "Fizz"
        } else {
            if n % 5 == 0 {
                print "Buzz"
            } else {
                print n
            }
        }
    }
}

# ── Fibonacci ─────────────────────────────────────────────────────────────────
print "\n=== Fibonacci ==="
fn fib(n) {
    if n <= 1 { return n }
    return fib(n - 1) + fib(n - 2)
}
print fib(10)   # 55

# ── Done ──────────────────────────────────────────────────────────────────────
print "\nAll tests passed!"
