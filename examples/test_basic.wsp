let s = "hello"
let b = true
print x
print s
print b

print 2 + 3
print 10 / 4
print 10 % 3

print "foo" + "bar"

if x > 10 { print "big" } else { print "small" }

let i = 0
while i < 3 {
    print i
    let i = i + 1
}

for n in range(0, 5) { print n }

fn double(n) { return n * 2 }
print double(7)

fn factorial(n) {
    if n <= 1 { return 1 }
    return n * factorial(n - 1)
}
print factorial(5)

